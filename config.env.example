# Copy to config.env and fill in for your account/VPC.
# cp config.env.example config.env

export AWS_REGION="${AWS_REGION:-us-east-1}"
# aws sts get-caller-identity --query Account --output text
export AWS_ACCOUNT_ID=""

export VPC_ID=""                    # e.g. vpc-0abc123
export VPC_CIDR="${VPC_CIDR:-172.31.0.0/16}"
export PRIVATE_SUBNET_ID=""         # metal host subnet (AZ-specific via parameters.json)
export ADMIN_CIDR="${ADMIN_CIDR:-172.31.0.0/16}"
export ASSOCIATE_PUBLIC_IP=true

export INSTANCE_TYPE=c7i.metal-48xl
export ROOT_NOTIFY_EMAIL=""         # CloudWatch alarm notifications
export CW_ALARM_PERIOD=120

# Reuses win-metal-hv-nic-{az} private /28 subnets from metal launch projects
export KVM_NIC_SUBNET_TAG_PREFIX=win-metal-hv-nic

# Only needed if ensure-kvm-nic-subnet.sh must CREATE transport /28s (JSON, one entry per AZ)
# export KVM_NIC_SUBNET_CIDRS='{"us-east-1a":"172.31.96.0/28","us-east-1b":"172.31.96.16/28"}'

# AVAILABILITY_ZONE / SITE_ID: pass on CLI (bin/run-site.sh). Do not export defaults here.
