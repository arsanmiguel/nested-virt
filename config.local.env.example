# Local overrides (not committed). Copy: cp config.local.env.example config.local.env

KEY_NAME=your-ec2-key-pair-name

# Optional: developer ISO overrides for bin/deploy-hyperv-guest.sh or on-metal prefetch.
# Drop-in CFN (nested-virt-lab.yaml) uses WindowsIsoDownloadUrl → Microsoft CDN by default.
# WINDOWS_ISO_DOWNLOAD_URL=https://your-mirror/Win2022.iso
# WINDOWS_ISO_S3_URI=s3://your-bucket/nested-virt/Win2022.iso
